{
  "name": "agenticmcpstores-for-woocommerce",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "wp-env:start": "wp-env start",
    "wp-env:stop": "wp-env stop",
    "wp-env:clean": "wp-env clean all",
    "test:setup": "bash tests/setup-test-env.sh",
    "test:e2e": "npx playwright test --config=tests/playwright.config.ts",
    "test:full": "npm run wp-env:start && npm run test:setup && npm run test:e2e",
    "test:teardown": "npm run wp-env:stop"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@wordpress/env": "^11.2.0"
  },
  "dependencies": {
    "@wordpress/i18n": "^6.18.0"
  }
}
