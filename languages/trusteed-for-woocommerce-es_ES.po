#. Plugin Name of the plugin
#: agenticmcpstores.php:3
msgid "AgenticMCPStores for WooCommerce"
msgstr "AgenticMCPStores para WooCommerce"

#. Description of the plugin
#: agenticmcpstores.php:5
msgid "Connect your WooCommerce store to AI agents via MCP (Model Context Protocol). Enable Claude, ChatGPT, and any MCP-compatible agent to search your catalog and create carts."
msgstr "Conecta tu tienda WooCommerce a agentes de IA mediante MCP (Model Context Protocol). Permite que Claude, ChatGPT y cualquier agente compatible con MCP busquen en tu catálogo y creen carritos."

#: agenticmcpstores.php:87
msgid "requires WooCommerce to be installed and active."
msgstr "requiere que WooCommerce esté instalado y activo."

